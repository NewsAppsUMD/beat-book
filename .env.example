# Copy this file to .env and fill in real values.
# Used by app.py at startup (see the loader near the top of that file).

# OpenAI — used only for embeddings (text-embedding-3-small).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Ollama Cloud — used for the chat models (ingest normalization,
# cluster labeling, the interview agent).
# Get one at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Anthropic — used by the research agent that revises the draft beat book.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional — point the chat model at a different Ollama endpoint
# (e.g. a self-hosted instance). Default is https://ollama.com/v1.
# OLLAMA_CHAT_BASE_URL=https://ollama.com/v1

# Optional — enable extended thinking / reasoning on the chat models
# (Opus 4.7 adaptive thinking + Qwen 3.5 thinking mode). Higher quality
# but materially slower. Default: off. Set to true/1/yes/on to enable.
# ENABLE_THINKING=true
